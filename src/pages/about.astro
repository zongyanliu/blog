---
/**
 * About page
 * URL: /about
 */
import PageLayout from '@/layouts/PageLayout.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import Badge from '@/components/ui/data-display/Badge/Badge.astro';
import Card from '@/components/ui/data-display/Card/Card.astro';
import Button from '@/components/ui/form/Button/Button.astro';
import { Hero } from '@/components/hero';
import TypingEffect from '@/components/ui/TypingEffect.astro';
import TechStack from '@/components/landing/TechStack.astro';
import { Image } from 'astro:assets';
import myAvatar from '@/assets/avatar.jpg';
---
<PageLayout
  title="About Zong-Yan Liu | Neural Genomes"
  description="Computational biologist pushing the boundaries of AI, genomics, and systems biology."
>
  <Hero layout="centered" size="sm">
    <Badge slot="badge" variant="brand" pill>
      <Icon name="user" size="sm" />
      About me
    </Badge>
    <h1 slot="title">
      <span class="text-foreground [-webkit-text-fill-color:currentColor]">Zong-Yan Liu —</span><br />
      <span class="text-brand-500 [-webkit-text-fill-color:var(--color-brand-500)]">
        <TypingEffect words={["Computational Biologist", "Machine Learning Enthusiast", "PhD Candidate", "Plant Geneticist"]} />
      </span>
    </h1>

    <p slot="description">
      I bridge computer science and plant genetics, deeply interested in how data science can advance our understanding of crop genomes and improve agricultural resilience.
    </p>
  </Hero>

  <!-- Biography -->
  <section class="py-[var(--space-section-md)] bg-brand-500/8 dark:bg-background-secondary border-t border-border">
    <div class="mx-auto max-w-6xl px-6">
      <div class="grid gap-12 lg:grid-cols-2">
        <div class="flex flex-col gap-4" data-reveal>
          <div class="flex flex-col gap-6">
            <Badge variant="brand" pill class="self-start">Background</Badge>
            <h2 class="font-display text-3xl md:text-4xl font-bold text-foreground">
              My Journey
            </h2>
          </div>
          <div class="mb-4">
            <Image 
              src={myAvatar} 
              alt="Zong-Yan Liu" 
              class="w-48 h-48 rounded-2xl object-cover shadow-lg border-2 border-brand-500/20"
            />
          </div>
          <p class="text-lg text-foreground-muted leading-relaxed">
            I am a fourth-year Ph.D. candidate at Cornell University in the <a href="https://www.maizegenetics.net/" target="_blank" rel="noopener noreferrer" class="underline underline-offset-2 decoration-brand-500 hover:text-brand-400 transition-colors">Buckler Lab</a> with a passion for computational biology and genetics. My background bridges computer science and plant genetics, and I’m deeply interested in how data science can advance our understanding of crop genomes.
          </p>
          <p class="text-lg text-foreground-muted leading-relaxed">
            Currently, I am conducting research in maize genetics, focusing on genomic prediction and statistical modeling to improve crop resilience. I am working on projects that utilize advanced computational techniques to enhance genomic analysis in maize, aiming to contribute to sustainable agriculture and food security.
          </p>
          
          <Button variant="outline" href="https://zongyanliu.github.io/web/Zong-Yan_Liu_CV_2025.pdf" target="_blank" class="self-start mt-4">
            Download CV
            <Icon name="download" size="sm" />
          </Button>
        </div>
        
        <div class="flex flex-col gap-4 h-full" data-reveal data-reveal-delay="1">
          <Card variant="elevated" class="flex-1 flex flex-col justify-center gap-4">
             <div class="flex items-start gap-4">
               <div class="w-11 h-11 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 shrink-0">
                 <Icon name="award" size="md" />
               </div>
               <div class="flex-1 min-w-0">
                 <h3 class="text-base font-semibold text-foreground">ASPB Ambassador</h3>
                 <p class="text-sm text-foreground-muted leading-relaxed mt-1.5">
                   Representing the global plant biology community by promoting scientific outreach and professional development.
                 </p>
               </div>
             </div>
          </Card>
          
          <Card variant="elevated" class="flex-1 flex flex-col justify-center gap-4">
             <div class="flex items-start gap-4">
               <div class="w-11 h-11 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 shrink-0">
                 <Icon name="users" size="md" />
               </div>
               <div class="flex-1 min-w-0">
                 <h3 class="text-base font-semibold text-foreground">Leadership</h3>
                 <p class="text-sm text-foreground-muted leading-relaxed mt-1.5">
                   President of Synapsis and the Cornell Taiwanese Student Association, fostering community and organizing professional opportunities.
                 </p>
               </div>
             </div>
          </Card>
        </div>
      </div>
    </div>
  </section>
  
  <!-- Education -->
  <section class="py-[var(--space-section-md)] border-t border-border">
    <div class="mx-auto max-w-6xl px-6">
      <div class="mb-8 text-center flex flex-col items-center gap-4" data-reveal>
        <div class="flex flex-col items-center gap-6">
          <Badge variant="brand" pill>Education</Badge>
          <h2 class="font-display text-4xl font-bold text-foreground">
            Academic Background
          </h2>
        </div>
      </div>
      <div class="grid gap-8 md:grid-cols-3" data-reveal data-reveal-delay="1">
        <Card hover>
          <div class="flex flex-col flex-1 h-full gap-4">
            <h3 class="text-xl font-semibold text-foreground">Cornell University</h3>
            <p class="text-sm font-bold text-brand-500">Ph.D. in Plant Breeding and Genetics</p>
            <p class="text-sm text-foreground-muted leading-relaxed">
              Focuses on developing advanced computational models to accurately predict gene structures and protein abundance in plants, enhancing our understanding of plant genomics. Utilizes large language models to predict plant gene structures and extends to modeling protein abundance of highly expressed genes.
            </p>
          </div>
        </Card>
        <Card hover>
          <div class="flex flex-col flex-1 h-full gap-4">
            <h3 class="text-xl font-semibold text-foreground">National Taiwan University</h3>
            <p class="text-sm font-bold text-brand-500">M.S. in Plant Biology</p>
            <p class="text-sm text-foreground-muted leading-relaxed">
              Analysis of IbHypSys-mediated MicroRNAs upon Wounding. Designed algorithms to identify plant microRNA target genes from sequencing data and cloned microRNA precursors into vectors to evaluate inhibitory effects on target gene expression.
            </p>
          </div>
        </Card>
        <Card hover>
          <div class="flex flex-col flex-1 h-full gap-4">
            <h3 class="text-xl font-semibold text-foreground">National Chung Hsing University</h3>
            <p class="text-sm font-bold text-brand-500">B.S. in Agronomy</p>
            <p class="text-sm text-foreground-muted leading-relaxed">
              Double minor in Management Information Systems and Applied Economics. Gained expertise in data management, systems analysis, and economic modeling. Conducted controlled experiments on the osmoregulation of rice seedlings.
            </p>
          </div>
        </Card>
      </div>
    </div>
  </section>

  <!-- My Stack -->
  <TechStack
    badge="Tools & Tech"
    title="Technical Skills"
    description="The languages and tools I use to bridge the gap between computer science and biology."
  />

  <!-- CTA -->
  <section class="py-[var(--space-section-md)] bg-background-secondary border-t border-border">
    <div class="mx-auto max-w-2xl px-6 text-center" data-reveal>
      <h2 class="font-display text-4xl font-bold text-foreground mb-4 text-balance">
        Let's Connect
      </h2>
      <p class="text-lg text-foreground-muted mb-8 text-balance">
        Whether you want to discuss AI models, plant genetics, or potential collaborations, don't hesitate to reach out!
      </p>
      <Button size="lg" href="/contact">
        Contact Me
        <Icon name="mail" size="sm" />
      </Button>
    </div>
  </section>
</PageLayout>
