    "eslint": "^9.17.0",
    "eslint-plugin-astro": "^1.3.0",
    "globals": "^15.14.0",
    "pagefind": "^1.3.0",
    "prettier": "^3.4.0",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.6.9",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.18.0",
